{
	"name": "varsity",
	"version": "1.0.11",
	"description": "Comprehensive OpenAPI parsing and validation library",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js"
		},
		"./cli": {
			"types": "./dist/types/src/cli.d.ts",
			"import": "./dist/cli.js"
		}
	},
	"bin": {
		"varsity": "dist/cli.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"start": "bun run src/cli.ts",
		"dev": "bun run --watch src/cli.ts",
		"test": "bun test",
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build:lib": "bun build index.ts --outdir dist --target node --format esm --external ajv --external ajv-formats --external commander --external js-yaml",
		"build:cli": "bun build src/cli.ts --outdir dist --target node --format esm --external ajv --external ajv-formats --external commander --external js-yaml",
		"build:types": "bun run --bun tsc -p tsconfig.build.json",
		"build": "bun run clean && bun run build:lib && bun run build:cli && bun run build:types",
		"lint": "bun run --bun tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"openapi",
		"swagger",
		"validation",
		"parser",
		"api",
		"specification",
		"cli",
		"typescript",
		"bun",
		"json-schema",
		"api-validation",
		"openapi-validator"
	],
	"author": "Luke",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LukasParke/varsity.git"
	},
	"homepage": "https://github.com/LukasParke/varsity#readme",
	"bugs": {
		"url": "https://github.com/LukasParke/varsity/issues"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.6.1",
		"typescript": "^5"
	},
	"dependencies": {
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"commander": "^14.0.1",
		"js-yaml": "^4.1.0",
		"oas-types": "^1.0.6"
	}
}
